# ─────────────────────────────────────────────────────────────────────────
# Repo Autopsy — environment
# Copy to .env.local and fill in.
# ─────────────────────────────────────────────────────────────────────────

# MiniMax (MiniMax) — OpenAI-compatible Chat Completions endpoint.
# Leave blank to run in offline / heuristic-only mode (uses a hardcoded
# sample patient, no GitHub fetch, no LLM call).
VITE_MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
VITE_MINIMAX_API_KEY=
VITE_MINIMAX_MODEL=MiniMax-Text-01

# GitHub — used to raise the unauthenticated rate limit (60 → 5000/hr).
# Optional. Public repos work without one.
VITE_GITHUB_TOKEN=
